{
  "mcpServers": {
    "zotero": {
      "command": "${HOME}/.local/bin/zotero-mcp",
      "env": { "ZOTERO_LOCAL": "true" }
    },
    "computer-use-linux": {
      "command": "${HOME}/.cargo/bin/computer-use-linux",
      "args": ["mcp"]
    },
    "github-anira": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN_ANIRA}"
      }
    }
  }
}
